# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sicoulab_database_development?sslmode=disable

# Server
SERVER_PORT=8080

# CORS settings
# カンマ区切りで複数のオリジンを指定可能
# 例: ALLOWED_ORIGINS=http://localhost:3000,https://example.com
ALLOWED_ORIGINS=http://localhost:3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Firebase Admin SDK
# サービスアカウントのJSONをそのまま記載する（改行は\nでエスケープ）
# 空の場合はApplication Default Credentials (ADC) を使用する
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
