# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sicoulab_database_development?sslmode=disable

# Server
# サーバーホスト（Docker環境では 0.0.0.0 を指定）
SERVER_HOST=localhost
SERVER_PORT=8080

# App Environment
# development: 開発環境（Secure=false、詳細ログ）
# production: 本番環境（Secure=true、本番ログ）
APP_ENV=development

# CORS settings
# カンマ区切りで複数のオリジンを指定可能
# 例: ALLOWED_ORIGINS=http://localhost:3000,https://example.com
ALLOWED_ORIGINS=http://localhost:3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Firebase Admin SDK
# FirebaseコンソールのプロジェクトID（設定 → 全般 → プロジェクトID）
FIREBASE_PROJECT_ID=your_firebase_project_id

# サービスアカウントのJSONをそのまま記載する（改行は\nでエスケープ）
# 空の場合はApplication Default Credentials (ADC) を使用する
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# UnivaPay
# UnivaPay ダッシュボードで取得したストアID / シークレット（テスト環境）
UNIVAPAY_STORE_ID=your_univapay_store_id
UNIVAPAY_STORE_SECRET=your_univapay_store_secret

# UnivaPay Webhook 署名検証用シークレット（UnivaPay ダッシュボードで設定した値と同一）
UNIVAPAY_WEBHOOK_SECRET=your_univapay_webhook_secret

# Cloud Storage（画像アップロード）
# GCSバケット名
GCS_BUCKET_NAME=sicoulab-assets-dev
# ストレージベースURL（アバター等のフルURL生成に使用）
# フロントエンドのNext.js rewritesでプロキシするため、フロントのオリジンを指定
STORAGE_BASE_URL=http://localhost:3000/storage/v1/b/sicoulab-assets-dev/o
# GCSエミュレータ（ローカル開発用。本番では設定しない）
STORAGE_EMULATOR_HOST=localhost:4443
