# Backend API URL
# 開発・本番環境でバックエンドAPIのURLを指定
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Log Level
# サーバーターミナルに出力するログレベル（error / warn / info / debug）
# 指定レベル以上のログのみ出力する（例: warn → error と warn を出力）
LOG_LEVEL=info

# Firebase Configuration
# Firebaseコンソール → プロジェクトの設定 → 全般 → SDKの設定と構成
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
# OAuth認証（signInWithPopup）に必須。形式: {project-id}.firebaseapp.com
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com

# UnivaPay Configuration
# UnivaPay管理画面 → ストア → アプリケーションJWTトークンのストアID部分
NEXT_PUBLIC_UNIVAPAY_APP_ID=your_univapay_app_id

# 外部リンクURL（設定画面）
# サブスクリプション管理ポータルURL（未設定時は管理リンク非表示）
NEXT_PUBLIC_SUBSCRIPTION_PORTAL_URL=https://widget.univapay.com/portal
# FAQページURL
NEXT_PUBLIC_FAQ_URL=https://sicou-lab.com/faq
# お問い合わせページURL
NEXT_PUBLIC_CONTACT_URL=https://sicou-lab.com/contact

# Firebase Auth Emulator（E2Eテスト用）
# 設定するとFirebase Auth Emulatorに接続する。通常の開発時はコメントアウト。
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
